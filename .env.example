# =============================================================
# PlaceMint — Root Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# =============================================================

# --- General ---
NODE_ENV=production
JWT_SECRET=your_jwt_secret_here_min_32_chars

# --- MongoDB URIs (one per service) ---
MONGO_URI_AUTH=mongodb://mongo:27017/authdb
MONGO_URI_PROFILE=mongodb://mongo:27017/profiledb
MONGO_URI_JOB=mongodb://mongo:27017/jobdb
MONGO_URI_APP=mongodb://mongo:27017/applicationdb
MONGO_URI_NOTIFY=mongodb://mongo:27017/notificationdb
MONGO_URI_QUIZ=mongodb://mongo:27017/quizdb
MONGO_URI_ANNOUNCE=mongodb://mongo:27017/announcedb
MONGO_URI_TASK=mongodb://mongo:27017/taskdb
MONGO_URI_HACKATHON=mongodb://mongo:27017/hackathondb
MONGO_URI_INTERVIEW=mongodb://mongo:27017/interviewdb
MONGO_URI_MESSAGING=mongodb://mongo:27017/messagingdb

# --- Redis ---
REDIS_URL=redis://redis-cache:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://rabbitmq:5672

# --- Email (SMTP-compatible provider) ---
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your_email@gmail.com
# MAIL_PASS=your_app_password
# MAIL_FROM=your_email@gmail.com

# --- reCAPTCHA ---
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
REACT_APP_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
SKIP_CAPTCHA_VERIFICATION=false

# --- TPO (Placement Cell Admin) ---
# Set this to the email that is allowed to register as 'placementcell' role
TPO_ADMIN_EMAIL=your_tpo_admin_email@example.com

# --- External APIs ---
JUDGE0_API_KEY=your_judge0_api_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
GEMINI_API_KEY=your_gemini_api_key_here

# --- Internal Service URLs (used inside Docker network) ---
AUTH_SERVICE_URL=http://auth-service:5001
PROFILE_SERVICE_URL=http://profile-service:5002
JOB_SERVICE_URL=http://job-service:5003
APPLICATION_SERVICE_URL=http://application-service:5004
NOTIFICATION_SERVICE_URL=http://notification-service:5005
SKILLS_SERVICE_URL=http://skills-service:5006
QUIZ_SERVICE_URL=http://quiz-service:5007
ANNOUNCEMENT_SERVICE_URL=http://announcement-service:5008
HACKATHON_SERVICE_URL=http://hackathon-service:5009
TASK_SERVICE_URL=http://task-service:5010
INTERVIEW_SERVICE_URL=http://interview-service:5011
MESSAGING_SERVICE_URL=http://messaging-service:5012

